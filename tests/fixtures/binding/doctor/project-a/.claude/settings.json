{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-precheck"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node format-check.mjs"
          }
        ]
      }
    ]
  },
  "skillOverrides": {
    "legacy-ecc-skill": "off"
  },
  "mcpServers": {
    "ecc-server": {
      "command": "ecc-mcp"
    }
  }
}
